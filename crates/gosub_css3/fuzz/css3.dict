"print"
"all"
"(min-width:"
"(max-width:"
"(min-height:"
"(max-height:"
"(orientation:"
"landscape"
"portrait"
"and"
"or"
"not"
"only"

# @supports conditions
"(display: grid)"
"(display: flex)"
"selector("

