"var(--foo, fallback)"

# Combinators and nesting
"&"
"& >"
"& +"
"& ~"

# Escape sequences
"\\\\"
"\\0"
"\\41"
"\\000041"

# Whitespace-sensitive tokens
"\x09"
"\x0A"
"\x0D\x0A"
"\x0C"

# Null / edge
"\x00"
